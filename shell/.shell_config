alias gpureload="sudo rmmod nvidia_uvm; sudo modprobe nvidia_uvm"

# Sunshine/Moonlight - wake display for remote connection
alias moonwake='WAYLAND_DISPLAY=wayland-0 XDG_RUNTIME_DIR=/run/user/1000 kscreen-doctor --dpms on && sleep 0.3 && WAYLAND_DISPLAY=wayland-0 XDG_RUNTIME_DIR=/run/user/1000 kscreen-doctor output.HDMI-A-2.enable'

# Alias for stringify script
alias gssh='function _gssh(){ gcloud compute ssh --project=corsali-development --zone=us-central1-a $1; }; _gssh'

# Alias for finding file descriptor offendors
#alias offenders="lsof -n | awk '{print \$2}' | sort | uniq -c | sort -rn | head -10 | xargs -I {} ps -p {} -o pid,ppid,cmd"
alias offenders='(echo "FDs     PID     PPID    CMD"; echo "---     ---     ----    ---"; lsof -n | awk '"'"'{print $2}'"'"' | sort | uniq -c | sort -rn | head -10 | awk '"'"'{print $2, $1}'"'"' | while read pid count; do printf "%-8s" "$count"; ps -p $pid -o pid=,ppid=,cmd= --no-headers | awk '"'"'{printf "%-8s %-8s %s\n", $1, $2, $3}'"'"'; done) | column -t'

#alias gcp-run='f(){ for i in $(seq $1 $2); do gcloud compute ssh --project=corsali-development --zone=us-central1-a root@$3-$i --command="$4"; done }; f'
alias gcp-run='f(){ if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then echo "Usage: gcp-run START_NUM END_NUM VM_PREFIX \"COMMAND\"\nRuns COMMAND on VMs named VM_PREFIX-N where N ranges from START_NUM to END_NUM\nExample: gcp-run 1 3 validator \"docker ps\""; return; fi; for i in $(seq $1 $2); do gcloud compute ssh --project=corsali-development --zone=us-central1-a root@$3-$i --command="$4"; done }; f'

