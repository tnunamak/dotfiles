# Shared shell config — sourced by both .zshrc and .bashrc

# Platform detection
case "$(uname)" in
  Darwin) IS_MACOS=1 ;;
  Linux)  IS_LINUX=1 ;;
esac

# Editor
export EDITOR=nvim
export VISUAL=nvim

# PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# GPG
export GPG_TTY=$(tty)

# Privacy
export DO_NOT_TRACK=1

# Kitty: use SSH kitten for automatic terminfo + shell integration
[[ "$TERM" == "xterm-kitty" ]] && alias ssh='kitten ssh'

# Aliases
alias ll='ls -lah'
alias la='ls -A'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline -20'

if [[ -n "$IS_LINUX" ]]; then
  alias pbcopy='xclip -selection clipboard'
fi

# Systemd (Linux only)
if [[ -n "$IS_LINUX" ]]; then
  alias sbase='systemctl --user'
  alias slist='systemctl --user list-units --type=service --all'
  alias son='systemctl --user start'
  alias soff='systemctl --user stop'
  alias slog='journalctl --user -f -u'
fi

alias lsports="sudo lsof -iTCP -sTCP:LISTEN -n -P | awk 'NR>1 {print \$9, \$1, \$2}' | sed 's/.*://' | while read -r port process pid; do echo \"Port \$port: \$(ps -p \$pid -o command= | sed 's/^-//') (PID: \$pid)\"; done | sort -n"

# Devcontainer helpers
if [[ -n "$IS_MACOS" ]]; then
  alias link-devcontainer='ln -sf "$HOME/code/dotfiles/devcontainer" .devcontainer'
else
  alias link-devcontainer='ln -sf /mnt/devcontainer-ro .devcontainer'
fi
alias unlink-devcontainer='rm .devcontainer'

# Kimi: ensure AGENTS.md exists in project dir (no global config support)
kimi() {
  [[ ! -e AGENTS.md ]] && [[ -f ~/code/dotfiles/ai/AGENTS.md ]] && \
    ln -s ~/code/dotfiles/ai/AGENTS.md AGENTS.md 2>/dev/null
  command kimi "$@"
}

droot() {
  if [[ -z "$1" ]] || [[ -z "$2" ]]; then
    echo "Usage: droot <container-name> <command...>"
    return 1
  fi
  local container="$1"
  shift
  docker exec -u root "$container" "$@"
}

firewall-on() {
  [[ -z "$1" ]] && { echo "Usage: firewall-on <container-name>"; return 1; }
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh on
}

firewall-off() {
  [[ -z "$1" ]] && { echo "Usage: firewall-off <container-name>"; return 1; }
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh off
}

firewall-status() {
  [[ -z "$1" ]] && { echo "Usage: firewall-status <container-name>"; return 1; }
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh status
}

# SSH agent (persistent across terminals)
if [[ -n "$IS_LINUX" ]]; then
  if [[ ! -S ~/.ssh/ssh_auth_sock ]]; then
    eval "$(ssh-agent -s)" > /dev/null
    ln -sf "$SSH_AUTH_SOCK" ~/.ssh/ssh_auth_sock
  fi
  export SSH_AUTH_SOCK=~/.ssh/ssh_auth_sock
  ssh-add -l > /dev/null 2>&1 || ssh-add -q
fi

# Secrets
[[ -f ~/.shell_secrets ]] && . ~/.shell_secrets

# Machine-specific config (nvm, conda, android, etc.)
[[ -f ~/.shell_local ]] && . ~/.shell_local

# Startup status (print cached, refresh in background)
if [[ $- == *i* ]] && [[ -z "$_SHELL_STATUS_RAN" ]]; then
  export _SHELL_STATUS_RAN=1
  [[ -f ~/.cache/shell-status/summary ]] && printf '%b\n' "$(cat ~/.cache/shell-status/summary)"
  ( shell-status-refresh &>/dev/null & )
fi
