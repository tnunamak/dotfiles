# alias unlink-devcontainer="sudo umount .devcontainer"

#alias link-devcontainer="ln -sf /home/tnunamak/code/claude-code/.devcontainer .devcontainer"
#alias unlink-devcontainer="rm .devcontainer"
# Run command as root in a devcontainer
# Usage: droot <container-name> <command...>
# Example: droot anka-redactor-dev apt update
droot() {
  if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: droot <container-name> <command...>"
    echo "Example: droot anka-redactor-dev apt update"
    return 1
  fi
  local container="$1"
  shift
  docker exec -u root "$container" "$@"
}

firewall-on() {
  if [ -z "$1" ]; then
    echo "Usage: firewall-on <container-name>"
    return 1
  fi
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh on
}

firewall-off() {
  if [ -z "$1" ]; then
    echo "Usage: firewall-off <container-name>"
    return 1
  fi
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh off
}

firewall-status() {
  if [ -z "$1" ]; then
    echo "Usage: firewall-status <container-name>"
    return 1
  fi
  docker exec "$1" /workspace/.devcontainer/research-mode-toggle.sh status
}


# Environment Variables
export PATH=$PATH:$HOME/.local/bin
export NVM_DIR="$HOME/.nvm"
export BUN_INSTALL="$HOME/.bun"
#export PATH=$BUN_INSTALL/bin:$PATH
export GPG_TTY=$(tty)
#export PATH=$(npm root -g)/../../bin:$PATH
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # Load nvm first
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
export PATH="$PATH:$(npm config get prefix --workspaces=false)/bin"  # Add npm global bin, ignore workspaces
#export PNPM_HOME="/home/tnunamak/.local/share/pnpm"
#export PATH="$PNPM_HOME:$PATH"
export PATH=$PATH:$HOME/applications/cursor/squashfs-root

if [ ! -S ~/.ssh/ssh_auth_sock ]; then
    echo "'ssh-agent' has not been started since the last reboot." \
         "Starting 'ssh-agent' now."
    eval "$(ssh-agent -s)"
    ln -sf "$SSH_AUTH_SOCK" ~/.ssh/ssh_auth_sock
fi
export SSH_AUTH_SOCK=~/.ssh/ssh_auth_sock
# see if any key files are already added to the ssh-agent, and if not, add them
ssh-add -l > /dev/null
if [ "$?" -ne "0" ]; then
    echo "No ssh keys have been added to your 'ssh-agent' since the last" \
         "reboot. Adding default keys now."
    ssh-add
fi

# NVM
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# Conda
# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/home/tnunamak/miniconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/home/tnunamak/miniconda3/etc/profile.d/conda.sh" ]; then
        . "/home/tnunamak/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="/home/tnunamak/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup
