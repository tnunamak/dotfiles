# Cargo (Rust)
. "$HOME/.cargo/env"

# Notify updates
#if [ -x "$(command -v apt)" ]; then
#  updates=$(apt list --upgradable 2>/dev/null | grep -v "Listing" | wc -l)
#  if [ "$updates" -gt 0 ]; then
#    echo "🔔 $updates package(s) can be upgraded. Run: sudo apt upgrade"
#  fi
#fi
if [ -x "$(command -v apt)" ]; then
  # Count packages that would actually be upgraded (not just listed as upgradable)
  upgrades=$(apt-get -s upgrade 2>/dev/null | grep "^Inst" | wc -l)
  if [ "$upgrades" -gt 0 ]; then
    echo "🔔 $upgrades package(s) can be upgraded. Run: sudo apt upgrade or sudo nala upgrade"
  fi
fi

# Disk cleanup suggestions (shows only if disk >75% or >5GB cleanable)
# Only run on interactive shells, not subshells or scripts
if [ -x "$HOME/.local/bin/cleanup-check" ] && [[ $- == *i* ]] && [ -z "$CLEANUP_CHECK_RAN" ]; then
  export CLEANUP_CHECK_RAN=1
  cleanup-check 2>/dev/null
fi

# Workstation issues tracker (background check, shows cached results)
if [ -x "$HOME/.local/bin/workstation-issues" ] && [[ $- == *i* ]] && [ -z "$WORKSTATION_ISSUES_RAN" ]; then
  export WORKSTATION_ISSUES_RAN=1
  workstation-issues 2>/dev/null
  # Refresh cache in background for next shell (no blocking)
  (workstation-issues --check-upstream --quiet &>/dev/null &)
fi

