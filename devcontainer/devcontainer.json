{
  "name": "Claude Code Sandbox",
  "initializeCommand": "mkdir -p ~/.devcontainer-homes/${localWorkspaceFolderBasename}/{.config,.local/share,.cache} ~/.claude ~/.codex ~/.gemini ~/.kimi ~/.config/{git,gh,gcloud,posthog} && touch ~/.claude/.credentials.json ~/.sentryclirc",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Chicago}",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
      "DEV_USER": "${localEnv:USER}"
    }
  },
  "runArgs": [
    "--name", "${localWorkspaceFolderBasename}-dev",
    "--device", "nvidia.com/gpu=all",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--privileged"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "${localEnv:USER}",
  "updateRemoteUserUID": true,
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.devcontainer-homes/${localWorkspaceFolderBasename},target=/home/${localEnv:USER},type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/${localEnv:USER}/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex,target=/home/${localEnv:USER}/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gemini,target=/home/${localEnv:USER}/.gemini,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.kimi,target=/home/${localEnv:USER}/.kimi,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/../,target=${localEnv:HOME}/code,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/${localEnv:USER}/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig.local,target=/home/${localEnv:USER}/.gitconfig.local,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/git,target=/home/${localEnv:USER}/.config/git,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/${localEnv:USER}/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gcloud,target=/home/${localEnv:USER}/.config/gcloud,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/${localEnv:USER}/.ssh,type=bind,readonly",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.sentryclirc,target=/home/${localEnv:USER}/.sentryclirc,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/posthog,target=/home/${localEnv:USER}/.config/posthog,type=bind,consistency=cached",
    "source=devcontainer-npm-cache,target=/home/${localEnv:USER}/.npm,type=volume",
    "source=devcontainer-bun-cache,target=/home/${localEnv:USER}/.bun/install/cache,type=volume",
    "source=devcontainer-pip-cache,target=/home/${localEnv:USER}/.cache/pip,type=volume",
    "source=devcontainer-pnpm-store,target=/home/${localEnv:USER}/.local/share/pnpm/store,type=volume",
    "source=devcontainer-cargo,target=/home/${localEnv:USER}/.cargo,type=volume",
    "source=devcontainer-rustup,target=/home/${localEnv:USER}/.rustup,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "SSH_AUTH_SOCK": "/ssh-agent",
    "EDITOR": "${localEnv:EDITOR:vim}",
    "VISUAL": "${localEnv:VISUAL:vim}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "KIMI_CODE_API_KEY": "${localEnv:KIMI_CODE_API_KEY}",
    "NGROK_AUTHTOKEN": "${localEnv:NGROK_AUTHTOKEN}",
    "SENTRY_AUTH_TOKEN": "${localEnv:SENTRY_AUTH_TOKEN}",
    "POSTHOG_PERSONAL_API_KEY": "${localEnv:POSTHOG_PERSONAL_API_KEY}",
    "HOST_HOME": "${localEnv:HOME}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=delegated",
  "workspaceFolder": "${localWorkspaceFolder}",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}
